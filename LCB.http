@LCB.Api_HostAddress = https://localhost:7274

### Login com Sucesso
# @name loginSuccess
POST {{ LCB.Api_HostAddress }}/auth/login
Accept: application/json
Content-Type: application/json

{
    "email": "steph@hoel.com",
    "password": "Hoel@1996"
}

### Capturar token JWT da resposta de login
@LCB.JwtToken = {{loginSuccess.response.body.$.data.token}}

### Login com Erro - 401
POST {{ LCB.Api_HostAddress }}/auth/login
Accept: application/json
Content-Type: application/json

{
    "email": "steph@hoel.com",
    "password": "1234"
}

### Registro com Sucesso - 201
POST {{ LCB.Api_HostAddress }}/auth/register
Accept: application/json
Content-Type: application/json

{
	"email": "new.user@livebridge.com",
	"password": "StrongP@ss1",
	"confirmPassword": "StrongP@ss1"
}

### Registro com Erro - 409 (email duplicado)
POST {{ LCB.Api_HostAddress }}/auth/register
Accept: application/json
Content-Type: application/json

{
	"email": "steph@hoel.com",
	"password": "StrongP@ss1",
	"confirmPassword": "StrongP@ss1"
}

### Registro com Erro - 400 (senha fora da política)
POST {{ LCB.Api_HostAddress }}/auth/register
Accept: application/json
Content-Type: application/json

{
	"email": "another.user@livebridge.com",
	"password": "1234",
	"confirmPassword": "1234"
}

### Documentação Swagger
GET {{ LCB.Api_HostAddress }}/swagger/v1/swagger.json

### Ingest TikTok message (entra na fila)
POST {{ LCB.Api_HostAddress }}/messages/ingest
Content-Type: application/json
Authorization: Bearer {{ LCB.JwtToken }}

{
	"provider": 0,
	"author": "testUser",
	"text": "!fila",
	"timestamp": "2026-04-06 14:00:00"
}
